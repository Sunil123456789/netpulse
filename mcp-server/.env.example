# ─── Required ────────────────────────────────────────────────────────────────

# Base URL of your running NetPulse server
NETPULSE_URL=http://localhost:5000

# Long-lived JWT from /api/auth/login (see README for how to get this)
NETPULSE_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────────────

# HTTP request timeout in milliseconds (default: 15000)
NETPULSE_TIMEOUT_MS=15000

# Set to true ONLY in dev environments with self-signed TLS certs
NETPULSE_TLS_SKIP_VERIFY=false

# Log level: debug | info | warn | error
MCP_LOG_LEVEL=warn
