# NetPulse Environment Configuration
# Copy this to .env and fill in your values

NODE_ENV=development
APP_PORT=5000
CLIENT_PORT=3000
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

ES_HOST=https://192.168.24.180:9200
ES_USER=elastic
ES_PASSWORD=your_elasticsearch_password
ES_CA_CERT_PATH=./certs/elasticsearch-ca.pem
ES_FIREWALL_INDEX=firewall-*
ES_CISCO_INDEX=cisco-*

MONGO_URI=mongodb://admin:netpulse_dev@mongo:27017/netpulse?authSource=admin
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_this_password

REDIS_URL=redis://:netpulse_dev@redis:6379
REDIS_PASSWORD=change_this_password

AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
ALERT_EMAIL_TO=noc@yourcompany.com

CORS_ORIGIN=http://localhost:3000
